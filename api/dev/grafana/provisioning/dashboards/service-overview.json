{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "panels": [
    {
      "type": "timeseries",
      "title": "HTTP request rate (per service)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum by (service_name) (rate(http_server_request_duration_seconds_count[1m]))",
          "legendFormat": "{{service_name}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "HTTP request duration p95 (s)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, service_name) (rate(http_server_request_duration_seconds_bucket[5m])))",
          "legendFormat": "{{service_name}}"
        }
      ]
    },
    {
      "type": "logs",
      "title": "Recent logs",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 8 },
      "targets": [
        { "expr": "{service_name=~\".+\"}", "refId": "A" }
      ],
      "options": { "showTime": true, "wrapLogMessage": true }
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["emailplatform"],
  "time": { "from": "now-15m", "to": "now" },
  "title": "Service Overview",
  "uid": "ep-service-overview",
  "version": 1
}
